    "selectors": {
      "card_container": ".internship_meta",
      "role_title": ".job-title-href",
      "company_name": ".company-name-container, .company_name",
      "stipend": ".stipend_container, .stipend",
      "duration": ".item_body",
      "apply_now_button": "#apply_now_button, button:has-text('Apply now'), .btn:has-text('Apply now')",
      "already_applied_indicator": ".applied_notification, button:has-text('Already applied'), .btn:has-text('Already applied')",
      "form_question_labels": "div.form-group:has(textarea) label.control-label, div.form-group:has(input[type='text']) label.control-label, .question-heading, .assessment_question",
      "form_text_inputs": "div.form-group textarea.form-control, div.form-group input[type='text'].form-control",
      "final_submit_button": "button:has-text('Submit'), input[type='submit']",
      "job_description": ".text-container.about_project_text, .job_summary"
    }
  
},

  "LINKEDIN_METADATA": {
    "platform_name": "LinkedIn",
    "base_url": "https://www.linkedin.com",
    "search_url": "https://www.linkedin.com/jobs/search/?keywords=Full%20Stack%20Developer&location=Noida",
    "selectors": {
      "card_container": ".job-search-card, .jobs-search-results-list__item, [data-occludable-job-id]",
      "role_title": ".job-card-list__title, .base-search-card__title",
      "company_name": ".job-card-container__company-name, .base-search-card__subtitle",
      "job_description": ".jobs-description__content, .jobs-box__html-content, [data-testid='expandable-text-box']",
      "easy_apply_button": "button:has-text('Easy Apply'), .jobs-apply-button:has-text('Easy Apply')",
      "already_applied_indicator": ".artdeco-inline-feedback--success, .jobs-s-apply__success-message, button:has-text('Applied')",
      "form_question_labels": "label.fb-dash-form-element__label, label.artdeco-text-input--label, div.jobs-easy-apply-form-section__grouping label",
      "form_text_inputs": "input.artdeco-text-input--input, textarea.artdeco-textarea-input",
      "form_select_dropdowns": "select.fb-dash-form-element__select-dropdown, select[data-test-text-entity-list-form-select]",
      "form_radio_inputs": "input[type='radio'].artdeco-radio-button__input",
      "form_checkbox_inputs": "input[type='checkbox'].artdeco-checkbox-button__input",
      "next_or_review_button": "button[data-live-test-easy-apply-next-button], button[data-live-test-easy-apply-review-button], button:has-text('Next'), button:has-text('Review')",
      "final_submit_button": "button[data-live-test-easy-apply-submit-button], button:has-text('Submit application'), button[aria-label='Submit application']"
    }
  
}
}